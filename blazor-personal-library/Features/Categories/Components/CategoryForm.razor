
<EntityForm 
    Entity="@Category" 
    CurrentPost="@CurrentPost" 
    FormPostWithExit="@FormPostWithExit" 
    InvalidForm="@InvalidForm" OnValidSumbit="@OnValidSumbit">

    <BPInputText Label="Name" @bind-Value="Category.Name" PlaceHolder="Action" />

</EntityForm>

@code {
    [Parameter, EditorRequired] public Category Category { get; set; } = null!;
    [Parameter, EditorRequired] public bool CurrentPost { get; set; } = false;
    [Parameter, EditorRequired] public bool FormPostWithExit { get; set; } = false;
    [Parameter, EditorRequired] public EventCallback OnValidSumbit { get; set; }
    [Parameter] public bool InvalidForm { get; set; } = true;

}
