@if (Books is null)
{
    <Loading />

}
else if (Books!.Count == 0)
{
    <text>No hay elementos a mostrar</text>
}
else
{
    <ul>
        @foreach (var book in Books!)
        {
            <BooksListItem @key="book.Id" Book="book" RemoveBook="RemoveBook" />
        }
    </ul>
}




@code {
    [Parameter, EditorRequired] public List<Book>? Books { get; set; }

    private void RemoveBook(Book book)
    {
        Books!.Remove(book);
    }

}
