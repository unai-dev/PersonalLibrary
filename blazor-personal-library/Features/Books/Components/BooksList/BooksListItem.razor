<img src="@Book.BookImage" class="img-fluid mb-2 w-100" style="height: 250px; object-fit: cover;" />
<div class="card-body p-2">
    
    <h5 class="fw-bold fst-italic">@Book.Title</h5>
    <p class="text-muted">@Book.Author</p>

    <div class="d-flex flex-row justify-content-end gap-3">
        <BPButton Variant="Variant.Danger" Width="Width.Full" Size="Size.Md" class="px-5" OnClick="@(() => RemoveBook.InvokeAsync(Book))">Remove</BPButton>
        <BPButton Variant="Variant.Success" Width="Width.Full" Size="Size.Md" class="px-5">Edit</BPButton>
    </div>  
    
</div>




@code {
    [Parameter, EditorRequired] public Book Book { get; set; }
    [Parameter] public EventCallback<Book> RemoveBook { get; set; }
}
