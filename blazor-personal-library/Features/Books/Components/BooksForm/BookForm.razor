
<div class="d-flex flex-column shadow-lg border-0 rounded-5 p-4">

    <EntityForm Entity="@Book"
                CurrentPost="@CurrentPost"
                FormPostWithExit="@PostWithExit"
                InvalidForm="@InvalidForm"
                OnValidSubmit="@PostForm">

        <div class="mb-3">
            <BPInputText Label="Title" @bind-Value="@Book.Title" PlaceHolder="El Quijote" />
        </div>

        <MultipleSelector Label="Categorias" Selects="categoriesSelect" NoSelects="categoriesDeselect" />

        <div class="mb-3">
            <BPInputImage Label="Imagen del Libro" ImageURL="@Book.BookImage" SelectImage="f => Book.FilePicture = f" />
        </div>

        <BPAutocompleteAuthor SelectAuthors="@AuthorsSelect"/>

    </EntityForm>

</div>


@code {
    [Parameter, EditorRequired] public List<Category> CategoriesDeselect { get; set; } = new List<Category>();
    [Parameter] public List<Category> CategoriesSelect { get; set; } = new List<Category>();

    [Parameter] public List<Author> AuthorsSelect { get; set; } = new List<Author>();

    [Parameter, EditorRequired] public Book Book { get; set; }
    [Parameter, EditorRequired] public bool CurrentPost { get; set; } = false;
    [Parameter, EditorRequired] public bool PostWithExit { get; set; } = false;
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public bool InvalidForm { get; set; } = true;

    private List<MultipleSelectorModel> categoriesDeselect = new List<MultipleSelectorModel>();
    private List<MultipleSelectorModel> categoriesSelect = new List<MultipleSelectorModel>();

    protected override void OnInitialized()
    {
        categoriesSelect = CategoriesSelect.Select(x => new MultipleSelectorModel(x.Id.ToString(), x.Name!)).ToList();
        categoriesDeselect = CategoriesDeselect.Select(x => new MultipleSelectorModel(x.Id.ToString(), x.Name!)).ToList();
    }

    private async Task PostForm()
    {
        Book.BookGenders = categoriesSelect.Select(x => new BookCategory { CategoryId = int.Parse(x.id) }).ToList();
        Book.BookAuthors = AuthorsSelect.Select((author) => new BookAuthor { AuthorId =  author.Id}).ToList();

        await OnValidSubmit.InvokeAsync();
    }
}



