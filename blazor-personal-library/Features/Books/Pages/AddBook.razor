@page "/books/add"

@inject IBookService bookService
@inject ICategoryService categoryService
@inject IAuthorService authorService
@inject NavigationManager navigationManager


<MainHeader Header="Agregar Libro" SubHeader="Agrega un nuevo libro a la libreria" />

<BookForm Book="@book"
          CurrentPost="@currentPost"
          PostWithExit="@formPostWithExit"
          OnValidSumbit="@AddNewBook" 
          CategoriesDeselect="@categoriesDeselect" CategoriesSelect="@categoriesSelect"
          AuthorsDeselect="@authorsDeselect" AuthorsSelect="@authorsSelect"
          />


@code {
    private Book? book;
    private List<Category>? categoriesSelect = new List<Category>();
    private List<Category>? categoriesDeselect = new List<Category>();

    private List<Author>? authorsSelect = new List<Author>();
    private List<Author>? authorsDeselect = new List<Author>();

    private bool currentPost = false;
    private bool formPostWithExit = false;

    protected override void OnInitialized()
    {
        book = new Book();
        categoriesDeselect = categoryService.GetCategories();
        authorsDeselect = authorService.GetAuthors();
    }

    private async Task AddNewBook()
    {
        if (!currentPost)
        {
            currentPost = true;

            bookService.AddNewBook(new Book
            {
                Title = book!.Title,
                State = book.State
            });

            await Task.Delay(2000);

            currentPost = false;
            formPostWithExit = true;

            navigationManager.NavigateTo("/");

            StateHasChanged();
        }

    }


}
